# Modelo de variáveis de ambiente do projeto.
# Copie este arquivo para ".env" e preencha com suas chaves reais.
# O arquivo .env NÃO deve ser versionado (está no .gitignore).

# Token de acesso pessoal do GitHub (https://github.com/settings/tokens)
GITHUB_TOKEN=

# Chave da API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
